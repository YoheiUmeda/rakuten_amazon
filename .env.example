# ============================================================
# .env.example
# 実際に使う場合はこのファイルを .env にコピーして各値を設定してください。
# ============================================================

# ── Keepa ──────────────────────────────────────────────────
KEEPA_API_KEY=your_keepa_api_key_here
KEEPA_QUERY_DIR=data/queries
KEEPA_REQUEST_UPPER_NUM=30
KEEPA_RANK_HISTORY_MIN_JUMP=1000
KEEPA_RANK_HISTORY_MIN_MINUTES=720
KEEPA_DOMAIN=5
KEEPA_FINDER_MIN_DROPS30=0
PREFILTER_MIN_SALES_RANK_DROPS30=0

# ── 楽天 ───────────────────────────────────────────────────
RAKUTEN_API_ID=your_rakuten_app_id_here
RAKUTEN_SLEEP_TIME=1.0
RAKUTEN_HITS=10
RAKUTEN_FAST_MODE=0
RAKUTEN_CACHE_PATH=rakuten_cache.json
RAKUTEN_MAX_RETRIES=3
MIN_RAKUTEN_PRICE=500

# ── Amazon SP-API ───────────────────────────────────────────
REFRESH_TOKEN=your_refresh_token
LWA_APP_ID=your_lwa_app_id
LWA_CLIENT_SECRET=your_lwa_client_secret
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
ROLE_ARN=arn:aws:iam::XXXXXXXXXXXX:user/YourRole
MARKETPLACE_ID=A1VC38T7YXB528
REQUEST_UPPER_NUM=20
MAX_RETRIES=5
FBA_SLEEP_TIME=11.5
CURRENCY=JPY
FBA_FEE_TABLE_PATH=data/fba_fee_table.csv

# ── フィルタ閾値 ────────────────────────────────────────────
MIN_PROFIT_YEN=700
MIN_ROI_PERCENT=15
PREFILTER_MIN_MAX_POSSIBLE_PROFIT=1500
PREFILTER_MIN_PRICE=3000

# ── 出力 ────────────────────────────────────────────────────
OUTPUT_DIR_PATH=./output
EXPORT_ONLY_FILTERED=false

# ── データベース ────────────────────────────────────────────
# [省略可能] Excel出力のみ使う場合は設定不要です。
# DB保存機能・FastAPI（/api/prices エンドポイント）を使う場合は必須です。
#
# Docker でローカルDB を起動する場合:
#   docker-compose -f infra/docker-compose.yml up -d
#
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/rakuten_amazon

# ── AI Orchestrator ────────────────────────────────────────
OPENAI_API_KEY=sk-...
# 試験運用: gpt-4o-mini（15日間）。本番移行時は gpt-4o 等に変更。
OPENAI_MODEL=gpt-4o-mini
